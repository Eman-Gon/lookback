# Core
DRAGBACK_ENV=development
# Memory resets default on locally. Uncomment only to opt a dedicated Neo4j demo database in.
# DRAGBACK_DEMO_RESET_ENABLED=true
DRAGBACK_GRANT_SECRET=replace-this-for-any-shared-demo
DRAGBACK_GRANT_TTL_SECONDS=3600
DRAGBACK_AUTHORITY_THRESHOLD=0.75

# Service URLs
DRAGBACK_AUTHORITY_URL=http://localhost:8001
DRAGBACK_AGENT_URL=http://localhost:8002
DRAGBACK_EXECUTOR_URL=http://localhost:8003
DRAGBACK_SERVICE_TIMEOUT_SECONDS=5
# Persistent Live Workspace state. This local file contains internal signed grants.
DRAGBACK_WORKSPACE_STORE=.dragback/live-workspaces.json

# Graph backend: memory | neo4j
DRAGBACK_GRAPH_BACKEND=memory
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=dragback-demo
NEO4J_DATABASE=neo4j

# Optional LLM integration. The deterministic demo does not require this.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Frontend
VITE_AUTHORITY_URL=http://localhost:8001
VITE_AGENT_URL=http://localhost:8002
VITE_EXECUTOR_URL=http://localhost:8003
